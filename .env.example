# Required: Google AI Studio Gemini API key
GEMINI_API_KEY=

# Required: Hugging Face Read token for gated RMBG-2.0 background removal
HF_TOKEN=

# Required: Roboflow Private API Key for the default SAM backend
ROBOFLOW_API_KEY=

# Optional: Roboflow endpoint override
ROBOFLOW_API_URL=https://serverless.roboflow.com/sam3/concept_segment
ROBOFLOW_API_FALLBACK_URLS=

# Optional: Docker DNS override for network/DNS issues
# DOCKER_DNS_1=223.5.5.5
# DOCKER_DNS_2=119.29.29.29
